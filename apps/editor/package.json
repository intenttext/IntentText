    "@dotit/core": "workspace:*",
    "@dotit/editor": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",

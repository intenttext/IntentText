{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Dotit main + per-document windows.",
  "windows": [
    "main",
    "doc-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-unminimize",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "window-state:default"
  ]
}

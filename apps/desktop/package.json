{
  "name": "intenttext-desktop",
  "private": true,
  "version": "3.0.0",
  "description": "Dotit Desktop (Electron) — document app for .it files",
  "main": "out/main/index.js",
  "author": "Dotit Labs",
  "scripts": {
    "build:deps": "pnpm --filter @dotit/core build && pnpm --filter @dotit/sign build && pnpm --filter @dotit/editor build",
    "dev": "pnpm run build:deps && electron-vite dev",
    "build": "pnpm run build:deps && electron-vite build",
    "start": "electron-vite preview",
    "dist": "pnpm run build && electron-builder",
    "dist:mac": "pnpm run build && electron-builder --mac"
  },
  "dependencies": {
    "@dotit/core": "workspace:*",
    "@dotit/editor": "workspace:*",
    "@dotit/sign": "workspace:^",
    "chokidar": "^4.0.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "~5.9.3"
  },
  "build": {
    "appId": "qa.uts.dotit",
    "productName": "Dotit",
    "publish": [
      {
        "provider": "github",
        "releaseType": "draft"
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        "nsis"
      ]
    },
    "fileAssociations": [
      {
        "ext": "it",
        "name": "Dotit Document",
        "role": "Editor"
      }
    ]
  }
}

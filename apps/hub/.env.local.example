# MongoDB connection string (e.g. Atlas or DigitalOcean Managed MongoDB)
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?tls=true&authSource=admin

# Set to 'true' to require manual approval for submissions
# Default: auto-approve everything that passes validation
REQUIRE_APPROVAL=false

# Admin token for the approval API endpoint
# Generate a random string: openssl rand -hex 32
ADMIN_TOKEN=replace-with-random-hex

# Session cookie signing secret (openssl rand -hex 32)
SESSION_SECRET=replace-with-random-hex

# GitHub OAuth app credentials (for login + template submission)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URL (for metadata and OG tags)
NEXT_PUBLIC_APP_URL=https://intenttext-hub.vercel.app

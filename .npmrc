# FROZEN / npm-only resolution. Every @dotit/* dependency resolves from the npm
# registry at its published version — NOT from the local workspace. This is the
# release state: the apps depend only on what's actually published. (To resume
# cross-package development, set this back to `true` so edits link locally.)
link-workspace-packages=false

# Don't require all packages to have the same version
# (editor, hub, docs etc. have their own versioning)
save-workspace-protocol=rolling

# Do NOT shamefully-hoist — causes esbuild binary version conflicts
# when apps use different versions (0.20 vs 0.28).
# Each package gets its own isolated node_modules via pnpm's virtual store.

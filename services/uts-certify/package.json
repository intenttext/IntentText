{
  "name": "@dotit/uts-certify",
  "private": true,
  "version": "0.2.0",
  "description": "Reference UTS certification service — the backend for api.uts.qa. Signs Ed25519 timestamps over .it document content (Phase 3a). Identity/KYC = 3b, billing = 3c.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx --watch src/server.ts",
    "start": "node dist/server.js",
    "gen-key": "node --import tsx scripts/gen-key.mjs",
    "issue-key": "node --import tsx scripts/issue-key.mjs",
    "root:init": "node --import tsx scripts/root-ca.mjs init",
    "root:issue": "node --import tsx scripts/root-ca.mjs issue",
    "root:pubkey": "node --import tsx scripts/root-ca.mjs pubkey",
    "test": "vitest run"
  },
  "dependencies": {
    "@dotit/core": "^1.2.4",
    "@dotit/sign": "^1.3.0",
    "express": "^5.2.1",
    "mongodb": "^7.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}

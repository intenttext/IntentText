{
  "name": "@dotit/uts-certify",
  "private": true,
  "version": "0.1.0",
  "description": "Reference UTS certification service — the backend for api.uts.qa. Signs Ed25519 timestamps over .it document content (Phase 3a). Identity/KYC = 3b, billing = 3c.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx --watch src/server.ts",
    "start": "node dist/server.js",
    "issue-key": "node --import tsx scripts/issue-key.mjs"
  },
  "dependencies": {
    "@dotit/sign": "workspace:^",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}

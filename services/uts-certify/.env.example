# UTS certification service — environment

# MongoDB (you connect your own engine; the service creates its collections):
MONGODB_URI=mongodb://localhost:27017
DB_NAME=uts

# Authority key custody.
#   UTS_KEY_PROVIDER=mongo (default): the Ed25519 signing key lives in MongoDB,
#     envelope-encrypted with UTS_KEK below. "All keys in MongoDB, securely."
#   UTS_KEY_PROVIDER=env: use a raw UTS_PRIVATE_KEY instead (KMS-style external secret).
UTS_KEY_PROVIDER=mongo

# KEK: 32-byte base64 AES-256 key that encrypts the signing key at rest in Mongo.
# Keep this in your secret manager — a DB dump WITHOUT this cannot forge anything.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
UTS_KEK=

# Only for UTS_KEY_PROVIDER=env (raw key, base64url). Leave blank when using mongo.
# Generate: pnpm gen-key
UTS_PRIVATE_KEY=

# Admin API (account onboarding + key minting). Required to use /admin/* routes.
UTS_ADMIN_TOKEN=

# ── Root → intermediate hierarchy (optional but recommended) ──────────────────
# The ROOT public key is the trust anchor verifiers PIN (baked into trust stores).
# Set it here and every certification chains to it via the intermediate cert; the
# service's own signing key becomes an "intermediate" the root vouches for. Leave
# blank to run legacy single-key mode (the signing key is the anchor). Generate
# the root OFFLINE: `UTS_ROOT_PASSPHRASE=… pnpm root:init` prints this value.
UTS_ROOT_PUBLIC_KEY=

# The ICA token (the root's signed vouch for THIS service's signing key), for env
# mode or as a bootstrap fallback in mongo mode. In mongo mode prefer POSTing it to
# /admin/intermediate-cert (it's stored on the active key doc). Mint it OFFLINE:
# `pnpm root:issue --root .root/root.json --intermediate-pub <intermediate> --days 365`.
UTS_ICA=

# OFFLINE-ONLY — the passphrase that encrypts the ROOT private key at rest. It is
# read ONLY by the root CLI (scripts/root-ca.mjs) on the air-gapped machine.
# DO NOT set this on the online service — the service never holds the root key.
UTS_ROOT_PASSPHRASE=

ISSUER=UTS
PORT=8787

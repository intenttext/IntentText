# ── UTS certification service configuration ──────────────────────────────────
# Copy to .env (gitignored) and fill in. Never commit real secrets.

# MongoDB you already run (one engine, many uses). The service creates its own
# collections + indexes inside DB_NAME on connect.
MONGODB_URI="mongodb://localhost:27017"
DB_NAME="uts"

# The UTS authority Ed25519 PRIVATE key (base64url). Generate with:
#   pnpm --filter @dotit/uts-certify gen-key
# In production this MUST come from your secret manager, NOT a committed file.
# If unset in dev, an ephemeral dev key is generated into .keys/uts.json (with a
# loud warning). If unset in production (NODE_ENV=production) the service refuses
# to start.
UTS_PRIVATE_KEY=""

# Shared admin token for the /admin/* endpoints (account + KYC + key minting).
# Separate from the per-account API keys. Use a long random value.
UTS_ADMIN_TOKEN=""

# Issuer name stamped into the certify: line (and the trust key in verifiers).
ISSUER="UTS"

# HTTP port.
PORT="8787"

# UTS certification service — environment

# MongoDB (you connect your own engine; the service creates its collections):
MONGODB_URI=mongodb://localhost:27017
DB_NAME=uts

# Authority key custody.
#   UTS_KEY_PROVIDER=mongo (default): the Ed25519 signing key lives in MongoDB,
#     envelope-encrypted with UTS_KEK below. "All keys in MongoDB, securely."
#   UTS_KEY_PROVIDER=env: use a raw UTS_PRIVATE_KEY instead (KMS-style external secret).
UTS_KEY_PROVIDER=mongo

# KEK: 32-byte base64 AES-256 key that encrypts the signing key at rest in Mongo.
# Keep this in your secret manager — a DB dump WITHOUT this cannot forge anything.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
UTS_KEK=

# Only for UTS_KEY_PROVIDER=env (raw key, base64url). Leave blank when using mongo.
# Generate: pnpm gen-key
UTS_PRIVATE_KEY=

# Admin API (account onboarding + key minting). Required to use /admin/* routes.
UTS_ADMIN_TOKEN=

ISSUER=UTS
PORT=8787

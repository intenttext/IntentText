    "prd-editor": {
      "name": "prd-editor",
      "file": "prd-editor.it",
      "file_abs": "../IntentText/examples/prd-editor.it",
      "modified": "2026-03-08T19:29:47.098507770+00:00",
      "document_count": 74,
      "documents": [
        {
          "_id": "b-1",
          "_line": 1,
          "type": "title",
          "_content": "Product Requirements Document - IntentText Editor",
          "_section": null,
          "_collection": "prd-editor"
        },
        {
          "_id": "b-2",
          "_line": 2,
          "type": "summary",
          "_content": "Requirements for a web-based IntentText editor with real-time collaboration",
          "_section": null,
          "_collection": "prd-editor"
        },
        {
          "_id": "b-3",
          "_line": 3,
          "type": "section",
          "_content": "Overview",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-4",
          "_line": 4,
          "type": "sub",
          "_content": "Problem Statement",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-5",
          "_line": 5,
          "type": "text",
          "_content": "Current IntentText workflow requires CLI tools and manual file management. Users need a visual editor with real-time preview and collaboration features.",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-6",
          "_line": 6,
          "type": "sub",
          "_content": "Solution",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-7",
          "_line": 7,
          "type": "list-item",
          "_content": "Web-based editor with live preview",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-8",
          "_line": 8,
          "type": "list-item",
          "_content": "Real-time collaboration (like Google Docs)",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-9",
          "_line": 9,
          "type": "list-item",
          "_content": "Visual block editor (Notion-style)",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-10",
          "_line": 10,
          "type": "list-item",
          "_content": "Built-in query and validation",
          "_section": "Overview",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-11",
          "_line": 11,
          "type": "section",
          "_content": "User Stories",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-12",
          "_line": 12,
          "type": "sub",
          "_content": "Writers",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-13",
          "_line": 13,
          "type": "list-item",
          "_content": "As a writer, I want to see formatted preview while typing so I can verify formatting",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-14",
          "_line": 14,
          "type": "list-item",
          "_content": "As a writer, I want to drag-and-drop blocks to reorganize content",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-15",
          "_line": 15,
          "type": "list-item",
          "_content": "As a writer, I want templates for common document types",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-16",
          "_line": 16,
          "type": "sub",
          "_content": "Developers",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-17",
          "_line": 17,
          "type": "list-item",
          "_content": "As a developer, I want to query documents programmatically so I can build tools",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-18",
          "_line": 18,
          "type": "list-item",
          "_content": "As a developer, I want schema validation to ensure document integrity",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-19",
          "_line": 19,
          "type": "list-item",
          "_content": "As a developer, I want to embed IntentText in my applications",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-20",
          "_line": 20,
          "type": "sub",
          "_content": "Teams",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-21",
          "_line": 21,
          "type": "list-item",
          "_content": "As a team member, I want to see who is editing in real-time",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-22",
          "_line": 22,
          "type": "list-item",
          "_content": "As a team member, I want to comment on specific blocks",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {
          "_id": "b-23",
          "_line": 23,
          "type": "list-item",
          "_content": "As a team member, I want notifications to notify colleagues",
          "_section": "User Stories",
          "_collection": "prd-editor"
        },
        {

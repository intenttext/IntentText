          "_content": "// IntentText Contract Template",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-2",
          "_line": 2,
          "type": "text",
          "_content": "// Use case: Service agreements, NDAs, court filings, legal correspondence",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-3",
          "_line": 3,
          "type": "font",
          "_content": "",
          "_section": null,
          "_collection": "templates/contract",
          "leading": 1.8,
          "size": "12pt",
          "family": "Times New Roman, serif"
        },
        {
          "_id": "b-4",
          "_line": 4,
          "type": "page",
          "_content": "",
          "_section": null,
          "_collection": "templates/contract",
          "footer": "{{contract.ref}} · Page {{page}} of {{pages}}",
          "margins": "25mm 30mm 25mm 30mm",
          "numbering": true,
          "size": "A4"
        },
        {
          "_id": "b-5",
          "_line": 5,
          "type": "title",
          "_content": "{{contract.title}}",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-6",
          "_line": 6,
          "type": "text",
          "_content": "This agreement (\"Agreement\") is entered into as of {{contract.date}} between:",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-7",
          "_line": 7,
          "type": "text",
          "_content": "{{party1.name}}, {{party1.type}}, registered at {{party1.address}} (\"Party A\"); and",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-8",
          "_line": 8,
          "type": "text",
          "_content": "{{party2.name}}, {{party2.type}}, registered at {{party2.address}} (\"Party B\").",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-9",
          "_line": 9,
          "type": "divider",
          "_content": "",
          "_section": null,
          "_collection": "templates/contract"
        },
        {
          "_id": "b-10",
          "_line": 10,
          "type": "section",
          "_content": "1. Scope of Services",
          "_section": "1. Scope of Services",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-11",
          "_line": 11,
          "type": "text",
          "_content": "{{sections.scope}}",
          "_section": "1. Scope of Services",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-12",
          "_line": 12,
          "type": "section",
          "_content": "2. Term",
          "_section": "2. Term",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-13",
          "_line": 13,
          "type": "text",
          "_content": "This Agreement commences on {{contract.startDate}} and continues until {{contract.endDate}}, unless terminated earlier in accordance with Section 8.",
          "_section": "2. Term",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-14",
          "_line": 14,
          "type": "section",
          "_content": "3. Compensation",
          "_section": "3. Compensation",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-15",
          "_line": 15,
          "type": "text",
          "_content": "Party B shall pay Party A the sum of {{contract.fee}} {{contract.currency}}, payable {{contract.paymentSchedule}}.",
          "_section": "3. Compensation",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-16",
          "_line": 16,
          "type": "section",
          "_content": "4. Confidentiality",
          "_section": "4. Confidentiality",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-17",
          "_line": 17,
          "type": "text",
          "_content": "Both parties agree to maintain strict confidentiality regarding all proprietary information exchanged during the term of this Agreement and for a period of {{contract.confidentialityPeriod}} thereafter.",
          "_section": "4. Confidentiality",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-18",
          "_line": 18,
          "type": "section",
          "_content": "5. Intellectual Property",
          "_section": "5. Intellectual Property",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-19",
          "_line": 19,
          "type": "text",
          "_content": "{{sections.ip}}",
          "_section": "5. Intellectual Property",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-20",
          "_line": 20,
          "type": "section",
          "_content": "6. Limitation of Liability",
          "_section": "6. Limitation of Liability",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-21",
          "_line": 21,
          "type": "text",
          "_content": "Neither party shall be liable for indirect, incidental, or consequential damages. Total liability shall not exceed {{contract.liabilityCap}} {{contract.currency}}.",
          "_section": "6. Limitation of Liability",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-22",
          "_line": 22,
          "type": "section",
          "_content": "7. Governing Law",
          "_section": "7. Governing Law",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-23",
          "_line": 23,
          "type": "text",
          "_content": "This Agreement shall be governed by the laws of {{contract.jurisdiction}}.",
          "_section": "7. Governing Law",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-24",
          "_line": 24,
          "type": "section",
          "_content": "8. Termination",
          "_section": "8. Termination",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-25",
          "_line": 25,
          "type": "text",
          "_content": "Either party may terminate this Agreement with {{contract.noticePeriod}} written notice. Termination for cause may be immediate upon written notice.",
          "_section": "8. Termination",
          "_collection": "templates/contract"
        },
        {
          "_id": "b-26",
          "_line": 26,
          "type": "section",
          "_content": "9. Entire Agreement",
          "_section": "9. Entire Agreement",
          "_collection": "templates/contract"
        },
        {

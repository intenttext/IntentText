// it-format: 1.0

page: | size: A4 | margin: 18mm
header: {{company.name}} — Tax Invoice
footer: Invoice {{invoice.number}} · Issued {{invoice.date}} · Page {{page}} of {{pages}}
watermark: {{invoice.status}} | opacity: 0.08

title: Tax Invoice {{invoice.number}}
summary: {{company.name}} → {{customer.name}}
meta: | type: invoice | ref: {{invoice.number}} | date: {{invoice.date}} | due: {{invoice.dueDate}} | status: {{invoice.status}} | currency: {{invoice.currency}} | theme: corporate | author: {{company.name}}

style: section | color: #0a5f7a | weight: 600
style: metric | weight: 600
style: table-header | bg: #0a5f7a | color: #ffffff

section: 1. Parties
sub: From
contact: {{company.name}} | role: Supplier | email: {{company.email}} | phone: {{company.phone}} | vat: {{company.vat}} | cr: {{company.cr}} | address: {{company.address}}

sub: Bill To
contact: {{customer.name}} | role: Customer | email: {{customer.email}} | phone: {{customer.phone}} | vat: {{customer.vat}} | address: {{customer.billingAddress}}

sub: Ship To
contact: {{customer.shipName}} | role: Recipient | address: {{customer.shippingAddress}} | attn: {{customer.shipContact}}

section: 2. Invoice Details
text: Invoice number | end: {{invoice.number}}

text: Purchase order | end: {{invoice.poNumber}}

text: Issue date | end: {{invoice.date}}

text: Payment due | end: {{invoice.dueDate}}

text: Payment terms | end: {{invoice.terms}}

text: Currency | end: {{invoice.currency}}

text: Account manager | end: {{invoice.accountManager}}

section: 3. Line Items
| # | Description | Qty | Unit | Unit Price | Discount % | Tax % | Amount | each: items |
| {{item.line}} | {{item.description}} | {{item.qty}} | {{item.unit}} | {{item.unitPrice}} | {{item.discount}} | {{item.taxRate}} | {{item.amount}} |

info: All amounts are stated in {{invoice.currency}} and exclude VAT unless a per-line tax rate is shown. | type: info

section: 4. Totals
metric: Subtotal | value: {{totals.subtotal}} | unit: {{invoice.currency}}
metric: Discount Total | value: {{totals.discount}} | unit: {{invoice.currency}}
metric: Taxable Amount | value: {{totals.taxable}} | unit: {{invoice.currency}}
metric: VAT ({{totals.taxRate}}%) | value: {{totals.tax}} | unit: {{invoice.currency}}
metric: Shipping & Handling | value: {{totals.shipping}} | unit: {{invoice.currency}}
metric: Total Due | value: [{{totals.due}}]{ size: 1.2em; weight: bold } | unit: {{invoice.currency}}

section: 5. Payment Instructions
sub: Bank Transfer
text: Beneficiary | end: {{payment.beneficiary}}

text: Bank | end: {{payment.bank}}

text: IBAN | end: {{payment.iban}}

text: SWIFT / BIC | end: {{payment.swift}}

text: Payment reference | end: {{invoice.number}}

deadline: Settlement due | date: {{invoice.dueDate}} | consequence: {{payment.latePolicy}}

term: Net payment | days: {{invoice.netDays}} | method: {{payment.method}}

term: Late fee | rate: {{payment.lateRate}} | basis: monthly on overdue balance

section: 6. Notes
text: {{invoice.notes}}

info: This is a computer-generated invoice. Please quote invoice number {{invoice.number}} on all correspondence and remittances. | type: tip

section: 7. Approvals
approve: Invoice prepared | by: {{approvals.preparedBy}} | role: Accounts | at: {{invoice.date}}
approve: Invoice reviewed | by: {{approvals.reviewedBy}} | role: Finance | at: {{approvals.reviewedAt}}

footnote: Registered in Qatar · CR {{company.cr}} · VAT {{company.vat}}

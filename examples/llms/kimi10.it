meta: | type: form | ref: VONB-2026-001 | theme: corporate

title: Vendor Onboarding Form
summary: New supplier registration — Al-Diwan Contracting W.L.L.

section: Company Information
input: Legal Company Name | key: company_name | type: text | required: yes
input: Trade Name (if different) | key: trade_name | type: text | required: no
input: Country of Registration | key: country | type: select | options: QA, SA, AE, KW, BH, OM, OTHER | required: yes
input: Commercial Registration Number | key: cr_number | type: text | required: yes
input: CR Document (PDF) | key: cr_document | type: attachment | required: yes

section: Tax & Banking
input: VAT / Tax Registration Number | key: vat_number | type: text | show-if: country == QA
input: Bank Name | key: bank_name | type: text | required: yes
input: IBAN | key: iban | type: text | required: yes
input: SWIFT/BIC | key: swift | type: text | required: yes

section: Contact Details
input: Primary Contact Name | key: contact_name | type: text | required: yes
input: Email Address | key: email | type: text | required: yes
input: Phone Number | key: phone | type: text | required: yes

section: Capabilities
input: Primary Trade Category | key: trade_category | type: select | options: Civil, MEP, Finishes, Joinery, Steel, Landscaping, Other | required: yes
input: Years in Business | key: years_experience | type: number | required: yes
input: Annual Turnover (QAR) | key: annual_turnover | type: number | required: yes

section: Compliance
input: ISO 9001 Certified? | key: iso_9001 | type: select | options: Yes, No, In Progress | required: yes
input: ISO 14001 Certified? | key: iso_14001 | type: select | options: Yes, No, In Progress | required: yes
input: Insurance Valid Until | key: insurance_expiry | type: date | required: yes

section: Computed Fields
input: Risk Score | key: risk_score | type: number | compute: (years_experience * 10) + (annual_turnover / 1000000)
input: Compliance Status | key: compliance_status | type: text | compute: iso_9001 == "Yes" && iso_14001 == "Yes" ? "Fully Compliant" : "Partially Compliant"

route: sequential
require: procurement
require: finance
require: compliance
page: | size: A4 | margin: 20mm
header: {{company.name}} | align: center
footer: {{invoice.number}} · Page {{page}} of {{pages}}

title: Invoice {{invoice.number}}
summary: {{company.name}} → {{customer.name}}
meta: | theme: corporate | date: {{invoice.date}} | status: {{invoice.status}} | ref: {{invoice.number}}

section: Bill To
contact: {{customer.name}} | role: Client | email: {{customer.email}} | vat: {{customer.vat}} | address: {{customer.address}}

section: Line Items
| Description | Qty | Unit Price | Total | each: items |
| {{item.description}} | {{item.qty}} | {{item.unitPrice}} | {{item.total}} |

section: Totals
metric: Subtotal | value: {{totals.subtotal}}
metric: Tax ({{totals.taxRate}}%) | value: {{totals.tax}}
metric: Total Due | value: {{totals.due}} | weight: bold

section: Payment Terms
deadline: Payment due | date: {{payment.dueDate}} | consequence: {{payment.lateFee}}
text: Bank transfer to: {{company.name}}, {{company.bankName}}, IBAN {{company.iban}}

section: Authorization
approve: Prepared by | by: {{preparer.name}} | role: {{preparer.role}} | at: {{preparer.date}}
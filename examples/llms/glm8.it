title: Customer Refund Approval Workflow
meta: | type: workflow

section: Trigger
trigger: id: t-01 | event: refund.requested | when: amount > 0

section: Steps
step: id: s-01 | tool: payments.lookup | desc: Retrieve original transaction
step: id: s-02 | tool: fraud.score | desc: Compute fraud risk score

section: Decision
decision: id: d-01 | desc: Route based on amount and fraud score | then: g-01 | else: g-02

section: Gates
gate: id: g-01 | desc: Auto-approve low-risk refunds
step: id: s-03 | tool: payments.refund | desc: Issue refund
result: id: r-01 | status: approved | desc: Refund auto-processed

gate: id: g-02 | desc: Manual review path
step: id: s-04 | tool: case.create | desc: Open review case
result: id: r-02 | status: pending | desc: Awaiting supervisor decision

section: Policies
policy: id: p-01 | text: No refund issued without a verified original transaction.
audit: id: a-01 | cite: REF-2025-048 | text: All refund decisions logged for 24 months.
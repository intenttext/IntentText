{
  "name": "@dotit/sign",
  "version": "2.0.0",
  "description": "Ed25519 cryptographic signatures for IntentText (.it) documents — provable 'who signed', self-verifying and offline. The opt-in identity layer on top of @dotit/core's integrity seal.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dotit-sign": "./cli.js"
  },
  "files": [
    "dist",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "keywords": [
    "intenttext",
    "ed25519",
    "signature",
    "crypto",
    "trust",
    "verify"
  ],
  "author": "UTS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/intenttext/IntentText.git",
    "directory": "packages/sign"
  },
  "homepage": "https://dotit.uts.qa",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dotit/core": "^2.0.5",
    "@noble/curves": "^1.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}

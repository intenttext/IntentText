{
  "name": "@intenttext/core",
  "version": "3.3.2",
  "description": "IntentText Parser, HTML Renderer, and Converters",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && npm run copy:wasm && npm run shim:parser",
    "copy:wasm": "mkdir -p dist/rust-wasm && cp src/rust-wasm/* dist/rust-wasm/",
    "test": "vitest run",
    "telemetry:report": "node scripts/report-fallback-telemetry.cjs",
    "size:report": "node scripts/report-package-size.cjs",
    "size:check": "node scripts/check-package-size.cjs",
    "pack:check": "node scripts/check-pack-footprint.cjs",
    "parser:coupling:check": "node scripts/check-no-parser-runtime-coupling.cjs",
    "shim:parser": "node scripts/shim-parser-runtime.cjs",
    "dev": "tsc --watch"
  },
  "keywords": [
    "intenttext",
    "parser",
    "markdown",
    "semantic",
    "ai"
  ],
  "author": "IntentText Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/intenttext/IntentText.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/intenttext/IntentText#readme",
  "bugs": {
    "url": "https://github.com/intenttext/IntentText/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "node-html-parser": "^7.0.2"
  }
}

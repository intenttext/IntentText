{
  "name": "minimal",
  "version": "1.0.0",
  "description": "Maximum whitespace, no decorative elements. High contrast.",
  "author": "IntentText",
  "fonts": {
    "body": "system-ui",
    "heading": "system-ui",
    "mono": "ui-monospace",
    "size": "11pt",
    "leading": "1.7"
  },
  "colors": {
    "text": "#111111",
    "heading": "#000000",
    "muted": "#555555",
    "accent": "#111111",
    "border": "#dddddd",
    "background": "#ffffff",
    "code-bg": "#f5f5f5",
    "trust-approved": "#16a34a",
    "trust-signed": "#2563eb",
    "trust-frozen": "#7c3aed",
    "trust-warning": "#dc2626",
    "watermark": "#00000008"
  },
  "spacing": {
    "page-margin": "20mm",
    "section-gap": "2.5em",
    "block-gap": "0.8em",
    "indent": "1em"
  },
  "blocks": {
    "section": {
      "font-weight": "700",
      "margin-top": "2.5em"
    },
    "quote": {
      "padding-left": "1em",
      "font-style": "italic",
      "color": "muted"
    }
  },
  "print": {
    "header-font-size": "8pt",
    "footer-font-size": "8pt",
    "header-color": "muted",
    "footer-color": "muted"
  }
}
{
  "name": "legal-dense",
  "version": "1.0.0",
  "description": "Contract style, packed tighter — long agreements, dense clauses",
  "author": "IntentText",
  "fonts": {
    "body": "Georgia",
    "heading": "Georgia",
    "mono": "Courier New",
    "size": "10.5pt",
    "leading": "1.4"
  },
  "colors": {
    "text": "#16181d",
    "heading": "#000000",
    "muted": "#4b5158",
    "accent": "#1f2937",
    "border": "#8b8f96",
    "background": "#ffffff",
    "code-bg": "#f4f4f5",
    "trust-approved": "#15602f",
    "trust-signed": "#1b3a5b",
    "trust-frozen": "#3f2a63",
    "trust-warning": "#7f1d1d",
    "watermark": "#00000008"
  },
  "spacing": {
    "page-margin": "20mm",
    "section-gap": "1.2em",
    "block-gap": "0.45em",
    "indent": "1.5em"
  },
  "blocks": {
    "text": {
      "text-align": "justify"
    },
    "prose": {
      "text-align": "justify"
    },
    "section": {
      "font-weight": "bold",
      "margin-top": "1.2em",
      "text-transform": "uppercase",
      "letter-spacing": "0.03em",
      "font-size": "0.9rem"
    },
    "sub": {
      "font-weight": "bold",
      "font-style": "italic"
    },
    "summary": {
      "font-style": "italic",
      "text-align": "justify"
    },
    "sign": {
      "border": "1px solid #000",
      "padding": "0.65em",
      "margin-top": "1.6em"
    },
    "freeze": {
      "border": "2px solid #000",
      "padding": "0.75em",
      "text-align": "center",
      "font-weight": "bold"
    }
  },
  "print": {
    "header-font-size": "8pt",
    "footer-font-size": "8pt",
    "header-color": "muted",
    "footer-color": "muted"
  }
}

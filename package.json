{
  "$schema": "https://www.schemastore.org/package",
  "name": "intenttext-monorepo",
  "version": "4.1.2",
  "description": "IntentText — monorepo for the core library, tools, apps, and integrations",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @dotit/core build",
    "build:mcp": "pnpm --filter @dotit/mcp build",
    "build:vscode": "pnpm --filter intenttext-vscode build",
    "build:action": "pnpm --filter intenttext-action build",
    "build:docs": "pnpm --filter intenttext-docs build",
    "build:editor": "pnpm --filter intenttext-editor build",
    "build:desktop": "pnpm --filter intenttext-desktop build",
    "build:hub": "pnpm --filter intenttext-hub build",
    "dev:editor": "pnpm --filter intenttext-editor dev",
    "dev:docs": "pnpm --filter intenttext-docs start",
    "dev:hub": "pnpm --filter intenttext-hub dev",
    "dev:desktop": "pnpm --filter intenttext-desktop dev",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @dotit/core test",
    "test:mcp": "pnpm --filter @dotit/mcp test",
    "demo": "node cli.js",
    "demo:invoice": "node demo/business-doc/pipeline.mjs",
    "demo:search": "node demo/folder-query/search.mjs",
    "demo:themes": "node demo/enterprise-themes/showcase.mjs",
    "demo:erp": "pnpm --filter intenttext-erp-demo start",
    "check:examples": "node scripts/check-examples.mjs",
    "parse": "node cli.js",
    "parse:html": "node cli.js examples/invoice.it --html",
    "browser:build": "pnpm --filter @dotit/core exec esbuild src/browser.ts --bundle --platform=browser --global-name=IntentText --outfile=../../intenttext.browser.js --format=iife --minify"
  },
  "keywords": [
    "intenttext",
    "parser",
    "markdown",
    "semantic",
    "ai",
    "mcp",
    "document"
  ],
  "author": "IntentText Team",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}

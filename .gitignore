# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build outputs ────────────────────────────────────────────
dist/
build/
media/
out/
*.tsbuildinfo
intenttext.browser.js

# Next.js
.next/
.vercel/

# Docusaurus
.docusaurus/

# Tauri / Rust
target/
*.rlib
Cargo.lock.bak

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
*.dist-info/
.pytest_cache/

# WASM build artifacts
*.wasm
rust-core_bg*

# ── Environment files ─────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Claude Code local state (settings.json may be tracked later; lock is per-machine)
.claude/scheduled_tasks.lock

# ── IDE files ─────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~

# VS Code workspace settings (keep extensions + tasks but not settings)
.vscode/settings.json
.vscode/launch.json

# ── OS generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ── Coverage ──────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────
jspm_packages/
.npm
.eslintcache
.turbo/
*.tgz

# Output files (except demo files)
*.html
sample-output.html
# …but Vite apps' entry HTML is SOURCE, not output — must be committed or the
# production build can't resolve its entry module (e.g. on Vercel).
!apps/*/index.html

# Temporary files
*.tmp
*.temp

# Local npm pack artifacts
intenttext-core-*.tgz
*.tgz

# This is a pnpm monorepo — the only lockfile is pnpm-lock.yaml.
package-lock.json

# Build / test output artifacts
apps/builder/artifacts/

# Keep GitHub Pages site files
!docs/**/*.html

# Demo generated outputs
demo/**/out.*

# Folder index cache (derived from .it files; safe to delete/regenerate)
.it-index

# VSCode extension package (build artifact)
*.vsix
